# ───── App ─────
PORT=4000
NODE_ENV=development

# ───── MongoDB ─────
# Local:   mongodb://localhost:27017/notifications
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/notifications
MONGO_URI=mongodb://localhost:27017/notifications

# ───── Redis ─────
# Local:   redis://localhost:6379
# Upstash: rediss://<user>:<pass>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ───── Auth ─────
# Must match the JWT_SECRET of your core NestJS app
# so frontend tokens are valid here too
JWT_SECRET=your_jwt_secret_here

# ───── CORS ─────
# Comma-separated list of allowed origins
# Next.js local:         http://localhost:3000
# React Native local:    http://localhost:8081
# Expo Go:               exp://192.168.x.x:8081
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ───── Cookie ─────
COOKIE_SECRET=your_cookie_secret_here
COOKIE_SAMESITE=lax
# In milliseconds: 86400000 = 1 day, 604800000 = 7 days
COOKIE_EXPIRATION=86400000