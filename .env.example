# ----- App -----
PORT=4000
NODE_ENV=development

# ----- MongoDB -----
# Local (Docker):   mongodb://localhost:27017
# Local with auth:  mongodb://<user>:<pass>@127.0.0.1:27017
# Atlas:            mongodb+srv://<user>:<pass>@cluster.mongodb.net
# Note: do NOT include the database name in the URI, use MONGO_DB_NAME instead
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=notifications

# ----- MongoDB Auth (production docker-compose only) -----
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=your_strong_mongo_password_here

# ----- Redis -----
# Local (Docker):   redis://localhost:6379
# Local with auth:  redis://:your_password@127.0.0.1:6379
# Upstash:          rediss://<user>:<pass>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ----- Redis Auth (production docker-compose only) -----
REDIS_PASSWORD=your_strong_redis_password_here

# ----- Auth -----
# Must match the JWT_SECRET of your core NestJS app
# so frontend tokens are valid here too
JWT_SECRET=your_jwt_secret_here

# ----- CORS -----
# Comma-separated list of allowed origins
# Next.js local:         http://localhost:3000
# React Native local:    http://localhost:8081
# Expo Go on device:     exp://192.168.x.x:8081
# Production web:        https://yourapp.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ----- Cookie -----
# Cookie secret - used to sign cookies
COOKIE_SECRET=your_cookie_secret_here
# lax = web (Next.js) | none = cross-site (requires HTTPS) | strict = same-site only
# Note: React Native authenticates via Authorization header, not cookies
COOKIE_SAMESITE=lax
# Expiration in milliseconds: 86400000 = 1 day | 604800000 = 7 days | 2592000000 = 30 days
COOKIE_EXPIRATION=86400000

# ----- API Keys -----
# Comma-separated keys - one per connected app
# Used in X-API-KEY request header from any app calling this service
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEYS=app_key_your_core_nestjs_app,app_key_another_app
